<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_card">

        <!-- Status Indicator Dot -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/status_dot_red" />

        <!-- App Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="VAYU"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offline"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Brain Server Status -->
    <TextView
        android:id="@+id/brainStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Brain: Checking..."
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#111122" />

    <!-- Chat Messages Area -->
    <ScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome message -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 VAYU ready. Type a task and hit Execute!"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="@drawable/msg_bubble_agent" />

        </LinearLayout>

    </ScrollView>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/bg_card">

        <!-- Task Input Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/taskInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="@string/hint_task"
                android:textColorHint="#666680"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="#1A1A3E"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:layout_marginEnd="8dp"
                android:singleLine="true"
                android:imeOptions="actionSend" />

            <Button
                android:id="@+id/btnExecute"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_execute"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_execute_bg"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:minWidth="100dp" />

        </LinearLayout>

        <!-- Stop + Settings Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnStop"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/btn_stop"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_stop_bg"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/btn_settings"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:background="#1A1A3E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
